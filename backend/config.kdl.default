// =============================================================================
// catevents — default configuration (KDL)
//
// This is the DEFAULT/template config. Copy it to `config.kdl` and edit:
//     cp config.kdl.default config.kdl
//
// `config.py` reads `config.kdl` if present, otherwise falls back to this file,
// and exposes every value below as a native Python variable.
//
// NOTE: HF_TOKEN is a secret. The HF_TOKEN environment variable always takes
// priority; the huggingface.hf_token value below is only a lower-priority
// fallback. NEVER put a real token in this committed template — set the env var,
// or copy this file to config.kdl (git-ignored) and put the token there.
// =============================================================================

// --- Hugging Face dataset target -------------------------------------------
huggingface {
    // Dataset repo that scraped trends are uploaded to / read back from.
    repo_id "YOUR_USERNAME/YOUR_DATASET"
    // Filename inside the dataset repo.
    remote_filename "trends.json"
    // Secret token for uploading to the dataset. The HF_TOKEN env var overrides
    // this. Leave the placeholder here; put a real token only in config.kdl.
    hf_token "YOUR_HF_TOKEN"
}

// --- AI summarization / keyword extraction ---------------------------------
// Uses an LLM to summarize the day's Google+Reddit trends and derive semantic
// search keywords that drive the Nitter/Camoufox search (replacing the static
// x.query when available; x.query is the fallback).
ai {
    // Master switch for AI API calls. When #false, NO AI request is made; the
    // pipeline uses classic (non-AI) semantic keyword extraction instead — see
    // `semantic_search` below.
    enabled #false

    // --- Feature flags -----------------------------------------------------
    // When `enabled` is #true, these choose what the AI is used for. If BOTH
    // ai_summarize and use_ai_to_find_nitter_result are #false while `enabled`
    // is #true, the AI system does nothing useful and a warning is logged
    // recommending you set `enabled` to #false.
    //
    // Summarize the day's trends with the AI API into `ai_summary`.
    ai_summarize #true
    // Use the AI API to derive the best Nitter search keywords (semantic).
    use_ai_to_find_nitter_result #true
    // Classic (non-AI) semantic keyword extraction from Google+Reddit. Used to
    // pick Nitter keywords when the AI is NOT finding them (either `enabled`
    // #false, or use_ai_to_find_nitter_result #false). #false = fall back to
    // the static x.query.
    semantic_search #true

    // API flavor. MUST be one of:
    //   "openai"    — OpenAI-compatible API   (POST {base_url}/chat/completions)
    //   "anthropic" — Anthropic-compatible API (POST {base_url}/v1/messages)
    api_type "openai"
    // Base URL of the API. For OpenAI-compatible endpoints include the /v1
    // suffix (e.g. "https://api.openai.com/v1"); for Anthropic-compatible use
    // the root (e.g. "https://api.anthropic.com").
    base_url "https://api.openai.com/v1"
    // Model name to use.
    model "gpt-4o-mini"
    // API key. The AI_API_KEY env var overrides this. Leave the placeholder in
    // this committed template; put a real key only in config.kdl.
    api_key "YOUR_AI_API_KEY"
    // Generation controls.
    max_tokens 512
    temperature 0.3
    // Request timeout (seconds).
    request_timeout 30
    // How many search keywords/queries the AI should return for Nitter.
    keyword_count 3
}

// --- Local cache -----------------------------------------------------------
cache {
    // On-disk JSON cache written after every scrape.
    local_file "trends_debug.json"
}

// --- HTTP server -----------------------------------------------------------
server {
    // Port is overridden by the PORT env var when present.
    port 5000
    host "0.0.0.0"
    debug #true
}

// --- Background scheduler ---------------------------------------------------
scheduler {
    enabled #true
    // Grace period after boot before the first background run (seconds).
    boot_delay_seconds 5
    // Delay between scheduled scrapes (seconds). 300 = 5 minutes.
    interval_seconds 300
}

// --- Shared feed parsing ---------------------------------------------------
feed {
    // Max items pulled from any single RSS/Atom feed.
    item_limit 10
}

// --- Google Trends ---------------------------------------------------------
google_trends {
    enabled #true
    // RSS endpoint; {geo} is substituted per region.
    url_template "https://trends.google.com/trending/rss?geo={geo}"
    // Per-region request timeout (seconds).
    request_timeout 5
    // Max unique trends kept after global aggregation.
    result_limit 15
    // High-volume, generally-unblocked country codes (mainland China excluded).
    geos "US" "GB" "CA" "AU" "NZ" "IE" \
         "FR" "DE" "IT" "ES" "NL" "BE" "CH" "AT" "SE" "NO" "DK" "FI" "PL" \
         "JP" "KR" "IN" "SG" "MY" "PH" "ID" "TH" "VN" "TW" "HK" \
         "BR" "MX" "AR" "CO" "CL" "PE" \
         "ZA" "NG" "KE" "EG" \
         "AE" "SA" "IL" "TR"
}

// --- Reddit ----------------------------------------------------------------
reddit {
    enabled #true
    url "https://www.reddit.com/r/popular/top/.rss?sort=top&t=day&limit=10"
    user_agent "RenderTrendBot/1.0 (contact: test@example.com)"
    default_score "▲ Popular"
    request_timeout 10
}

// --- X / Twitter -----------------------------------------------------------
x {
    // Master switch — flip to #true to re-enable X scraping.
    enabled #false
    user_agent "Mozilla/5.0 (Windows NT 10.0; Win64; x64)"
    // Search query appended to each mirror's /search/rss endpoint.
    query "#trending"
    request_timeout 8
    default_score "Trending"
    // Nitter-style mirror instances, tried in order.
    mirrors "xcancel.com" \
            "nitter.net" \
            "nuku.trabun.org" \
            "nitter.space" \
            "nitter.privacyredirect.com" \
            "nitter.kareem.one" \
            "nitter.poast.org" \
            "nitter.catsarch.com"
}

// --- Camoufox stealth browser scraper --------------------------------------
camoufox {
    enabled #true
    // Run the patched Firefox without a visible window.
    headless #true
    // Add human-like cursor movement.
    humanize #true
    // Default CSS selector for extracting text snippets.
    default_selector "h1, h2, h3"
    // Max snippets returned per page.
    default_limit 10
    // Navigation timeout (milliseconds).
    timeout_ms 30000
    // Extra wait for client-side rendering after load (milliseconds).
    settle_ms 2000
    // Retry attempts on navigation failure.
    max_retries 2
    // Block heavy resource types to speed up scraping. Empty = block nothing.
    block_resources "image" "font" "media"
    // Optional upstream proxy, e.g. "http://user:pass@host:port". Empty = none.
    proxy ""
    // Default page to scrape when run standalone.
    default_url "https://news.ycombinator.com"
    // Selector used by the standalone demo run.
    default_demo_selector ".titleline > a"
}

// --- Trend ranking / quicksort --------------------------------------------
// Controls how Google Trends & Reddit items are ranked. The quicksort orders
// by highest search volume, then most abnormal 24h frequency, then title.
sorting {
    // Sort trends by volume/abnormality (uses the custom quicksort). When
    // #false, scraped order is preserved.
    enabled #true
    // Sort order for the primary key: "desc" (highest volume first) or "asc".
    order "desc"
    // Case-insensitive alphabetical tie-break. #true upper-cases before the
    // ASCII(-32) conversion so 'a' and 'A' fold together.
    case_insensitive #true
    // Weight the abnormality (24h spike z-score) as a tie-break between items
    // of equal volume. Set #false to tie-break on title only.
    use_abnormality #true
    // ASCII offset subtracted from each char code when building the sort key.
    // Per spec this is 32 (space); rarely needs changing.
    ascii_offset 32
}
